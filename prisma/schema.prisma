generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model StripeWebhookEvent {
  eventId    String   @id
  eventType  String
  status     String   @default("received")
  receivedAt DateTime @default(now())
  updatedAt   DateTime @updatedAt
  error      String?  @db.Text

  @@index([status, receivedAt])
  @@index([receivedAt])
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          Role      @default(STUDENT)
  plan          String    @default("FREE")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Profile
  gradeLevel         String?
  curriculum         String?
  subjects           String[]
  gpa                Float?
  satScore           Int?
  actScore           Int?
  intendedMajor      String?
  targetUniversities String[]
  careerInterests    String[]
  location           String?
  bio                String?   @db.VarChar(100)
  coursesTaking      String[]  @default([])
  activitiesDone     Json?
  goals              Json?
  customPreferences  String?   @db.Text
  weeklyAvailability Json?

  // Subscription
  stripeCustomerId     String?   @unique
  stripeSubscriptionId String?   @unique
  stripePriceId        String?
  subscriptionStatus   String?
  subscriptionEnds     DateTime?
  trialEnds            DateTime?

  accounts             Account[]
  sessions             Session[]
  studyMaterials       StudyMaterial[]
  worksheets           Worksheet[]
  pastPapers           PastPaper[]
  essays               Essay[]
  chatMessages         ChatMessage[]
  studySessions        StudySession[]
  sidebarPreference    SidebarPreference?
  notes                Note[]
  flashcardDecks       FlashcardDeck[]
  flashcards           Flashcard[]
  flashcardReviews     FlashcardReview[]
  userStats            UserStats?
  eventLogs            EventLog[]
  goalsV2              Goal[]
  deadlinesV2          Deadline[]
  calendarEvents       CalendarEvent[]
  feedbackItems        Feedback[]
  practiceSessionsV2   PracticeSession[]
  studentProfile       StudentProfile?
  tutorProfile         TutorProfile?
  parentProfile        ParentProfile?
  tutoringTasksOwned   TutoringTask[] @relation("TutoringTaskStudent")
  tutoringTasksAssigned TutoringTask[] @relation("TutoringTaskAssigner")
  tutoringSubmissions  TutoringSubmission[] @relation("TutoringSubmissionStudent")
  tutoringSubmissionsAuthored TutoringSubmission[] @relation("TutoringSubmissionSubmitter")
  tutoringFeedbackGiven TutoringFeedback[] @relation("TutoringFeedbackReviewer")
  tutoringResourcesUploaded TutoringResource[] @relation("TutoringResourceUploader")
  tutoringResourcesForStudent TutoringResource[] @relation("TutoringResourceStudent")
  tutoringStudentLinks TutoringStudentTutor[] @relation("TutoringStudentTutorStudent")
  tutoringTutorLinks    TutoringStudentTutor[] @relation("TutoringStudentTutorTutor")
  tutoringParentLinksAsStudent TutoringStudentParent[] @relation("TutoringStudentParentStudent")
  tutoringParentLinksAsParent TutoringStudentParent[] @relation("TutoringStudentParentParent")
}

model SidebarPreference {
  id         String   @id @default(cuid())
  userId     String   @unique
  collapsed  Boolean  @default(false)
  openGroups String[] @default([])
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Note {
  id        String   @id @default(cuid())
  userId    String
  title     String
  content   String   @db.Text
  tags      String[] @default([])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, updatedAt])
}

model FlashcardDeck {
  id          String      @id @default(cuid())
  userId      String
  name        String
  description String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  cards       Flashcard[]

  @@index([userId, updatedAt])
}

model Flashcard {
  id        String           @id @default(cuid())
  deckId    String
  userId    String
  front     String           @db.Text
  back      String           @db.Text
  tags      String[]         @default([])
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  deck      FlashcardDeck    @relation(fields: [deckId], references: [id], onDelete: Cascade)
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  reviews   FlashcardReview[]

  @@index([deckId])
  @@index([userId])
}

model FlashcardReview {
  id          String    @id @default(cuid())
  cardId      String
  userId      String
  easiness    Float     @default(2.5)
  interval    Int       @default(1)
  repetitions Int       @default(0)
  dueDate     DateTime  @default(now())
  lastScore   Int?
  reviewedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  card        Flashcard @relation(fields: [cardId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([cardId, userId])
  @@index([userId, dueDate])
}

model UserStats {
  id                    String   @id @default(cuid())
  userId                String   @unique
  studySessionsCount    Int      @default(0)
  notesCount            Int      @default(0)
  flashcardsReviewed    Int      @default(0)
  practiceSessionsCount Int      @default(0)
  correctAnswersCount   Int      @default(0)
  totalAnswersCount     Int      @default(0)
  currentStreakDays     Int      @default(0)
  longestStreakDays     Int      @default(0)
  lastActiveDate        DateTime?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model EventLog {
  id        String   @id @default(cuid())
  userId    String
  eventType String
  meta      Json?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model Goal {
  id          String    @id @default(cuid())
  userId      String
  title       String
  description String?   @db.Text
  status      String    @default("active")
  targetDate  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  deadlines   Deadline[]

  @@index([userId, status])
}

model Deadline {
  id        String    @id @default(cuid())
  userId    String
  goalId    String?
  title     String
  dueAt     DateTime
  priority  String    @default("medium")
  completed Boolean   @default(false)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  goal      Goal?     @relation(fields: [goalId], references: [id], onDelete: SetNull)

  @@index([userId, dueAt])
}

model CalendarEvent {
  id        String   @id @default(cuid())
  userId    String
  title     String
  startsAt  DateTime
  endsAt    DateTime
  source    String   @default("manual")
  module    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, startsAt])
}

model Question {
  id          String   @id @default(cuid())
  userId      String
  subject     String
  topic       String
  difficulty  String
  stem        String   @db.Text
  options     Json?
  answer      String   @db.Text
  explanation String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId, subject, topic])
}

model PracticeSession {
  id          String           @id @default(cuid())
  userId      String
  subject     String
  startedAt   DateTime         @default(now())
  completedAt DateTime?
  score       Float?
  results     PracticeResult[]
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, startedAt])
}

model PracticeResult {
  id             String          @id @default(cuid())
  sessionId      String
  questionId     String
  selectedAnswer String?
  isCorrect      Boolean
  createdAt      DateTime        @default(now())
  session        PracticeSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
}

model Feedback {
  id        String   @id @default(cuid())
  orgId     String?
  userId    String?
  email     String?
  category  String   @default("general")
  message   String   @db.Text
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([orgId, createdAt])
  @@index([orgId, userId, createdAt])
  @@index([orgId, category, createdAt])
}

model ChangelogEntry {
  id        String   @id @default(cuid())
  version   String
  title     String
  content   String   @db.Text
  createdAt DateTime @default(now())

  @@index([createdAt])
}

enum Role {
  USER
  ADMIN
  OWNER
  TUTOR
  PARENT
  STUDENT
}

model StudyMaterial {
  id          String   @id @default(cuid())
  userId      String
  title       String
  subject     String
  level       String?
  curriculum  String?
  contentType String
  content     String?  @db.Text
  fileUrl     String?
  summary     String?  @db.Text
  notes       String?  @db.Text
  flashcards  Json?
  keyTopics   String[]
  studyPlan   String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Worksheet {
  id           String   @id @default(cuid())
  orgId        String?
  userId       String
  title        String
  subject      String
  curriculum   String?
  difficulty   String
  questionType String
  questions    Json
  answers      Json?
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([orgId, createdAt])
  @@index([orgId, userId, createdAt])
}

model PastPaper {
  id          String    @id @default(cuid())
  userId      String
  subject     String
  curriculum  String
  year        Int?
  duration    Int
  questions   Json
  answers     Json?
  score       Float?
  timeSpent   Int?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Essay {
  id         String   @id @default(cuid())
  userId     String
  type       String
  university String?
  prompt     String?  @db.Text
  draft      String?  @db.Text
  feedback   String?  @db.Text
  improved   String?  @db.Text
  wordCount  Int?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ChatMessage {
  id        String   @id @default(cuid())
  userId    String
  role      String
  content   String   @db.Text
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model StudySession {
  id          String   @id @default(cuid())
  userId      String
  title       String
  subject     String
  curriculum  String?
  content     String   @db.Text
  summary     String?  @db.Text
  flashcards  Json?
  studyPlan   String[] @default([])
  keyConcepts String[] @default([])
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model ActivityOpportunity {
  id              String   @id @default(cuid())
  orgId           String?
  createdByUserId String
  title           String
  providerName    String?
  description     String   @db.Text
  category        String
  mode            String   @default("online")
  region          String?
  eligibility     Json?
  costMin         Float?
  costMax         Float?
  currency        String?  @default("USD")
  hoursPerWeekMin Int?
  hoursPerWeekMax Int?
  durationWeeks   Int?
  deadlineAt      DateTime?
  sourceType      String   @default("manual")
  sourceUrl       String?
  status          String   @default("needs_review")
  verifiedAt      DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tags              ActivityOpportunityTag[]
  evidenceTemplates ActivityEvidenceTemplate[]
  reviewLogs        ActivityReviewLog[]

  @@index([orgId, status, category])
  @@index([createdByUserId, createdAt])
}

model ActivityOpportunityTag {
  id         String   @id @default(cuid())
  activityId String
  tag        String
  createdAt  DateTime @default(now())

  activity ActivityOpportunity @relation(fields: [activityId], references: [id], onDelete: Cascade)

  @@index([activityId])
  @@index([tag])
  @@unique([activityId, tag])
}

model ActivityEvidenceTemplate {
  id             String   @id @default(cuid())
  activityId      String
  title           String
  description     String   @db.Text
  sampleArtifact  String?
  createdAt       DateTime @default(now())

  activity ActivityOpportunity @relation(fields: [activityId], references: [id], onDelete: Cascade)

  @@index([activityId])
}

model ActivityReviewLog {
  id         String   @id @default(cuid())
  activityId String
  reviewerId String
  action     String
  notes      String?  @db.Text
  createdAt  DateTime @default(now())

  activity ActivityOpportunity @relation(fields: [activityId], references: [id], onDelete: Cascade)

  @@index([activityId, createdAt])
  @@index([reviewerId, createdAt])
}

model StudentProfile {
  id            String   @id @default(cuid())
  userId        String   @unique
  gradeLevel    String?
  curriculum    String?
  schoolName    String?
  weeklyGoal    String?  @db.Text
  notes         String?  @db.Text
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([gradeLevel, curriculum])
}

model TutorProfile {
  id               String   @id @default(cuid())
  userId           String   @unique
  specialties      String[]  @default([])
  bio              String?   @db.Text
  weeklyCapacity   Int?
  notes            String?   @db.Text
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ParentProfile {
  id                String   @id @default(cuid())
  userId            String   @unique
  householdLabel    String?
  preferredChannel  String?  @default("email")
  notes             String?  @db.Text
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model TutoringStudentTutor {
  id               String   @id @default(cuid())
  studentUserId    String
  tutorUserId      String
  relationshipLabel String?
  isPrimary        Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  student          User     @relation("TutoringStudentTutorStudent", fields: [studentUserId], references: [id], onDelete: Cascade)
  tutor            User     @relation("TutoringStudentTutorTutor", fields: [tutorUserId], references: [id], onDelete: Cascade)

  @@unique([studentUserId, tutorUserId])
  @@index([tutorUserId])
  @@index([studentUserId])
}

model TutoringStudentParent {
  id                String   @id @default(cuid())
  studentUserId     String
  parentUserId      String
  relationshipLabel String?
  receivesUpdates   Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  student           User     @relation("TutoringStudentParentStudent", fields: [studentUserId], references: [id], onDelete: Cascade)
  parent            User     @relation("TutoringStudentParentParent", fields: [parentUserId], references: [id], onDelete: Cascade)

  @@unique([studentUserId, parentUserId])
  @@index([parentUserId])
  @@index([studentUserId])
}

enum TutoringTaskStatus {
  ASSIGNED
  SUBMITTED
  REVIEWED
  OVERDUE
  COMPLETED
}

enum TutoringResourceKind {
  LESSON_FILE
  QUESTION_BANK
  MODEL_ANSWER
  TUTOR_RESOURCE
}

enum TutoringAccessTier {
  FREE
  AI_PREMIUM
  TUTORING_PREMIUM
  TUTOR_ONLY
}

model TutoringTask {
  id               String              @id @default(cuid())
  studentUserId    String
  assignedByUserId String
  subject          String
  topic            String
  title            String
  instructions     String              @db.Text
  status           TutoringTaskStatus  @default(ASSIGNED)
  dueAt            DateTime?
  completedAt      DateTime?
  priority         String              @default("medium")
  completionNote   String?             @db.Text
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  student          User                @relation("TutoringTaskStudent", fields: [studentUserId], references: [id], onDelete: Cascade)
  assignedBy       User                @relation("TutoringTaskAssigner", fields: [assignedByUserId], references: [id], onDelete: Cascade)
  submissions      TutoringSubmission[]
  feedback         TutoringFeedback[]
  resources        TutoringResource[]

  @@index([studentUserId, status, dueAt])
  @@index([assignedByUserId, createdAt])
  @@index([subject, topic])
}

model TutoringSubmission {
  id                String   @id @default(cuid())
  taskId            String
  studentUserId     String
  submittedByUserId String
  submittedAt       DateTime @default(now())
  textResponse      String?  @db.Text
  fileName          String?
  fileMimeType      String?
  fileBytes         Bytes?
  externalLink      String?
  notes             String?  @db.Text
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  task              TutoringTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  student           User         @relation("TutoringSubmissionStudent", fields: [studentUserId], references: [id], onDelete: Cascade)
  submittedBy       User         @relation("TutoringSubmissionSubmitter", fields: [submittedByUserId], references: [id], onDelete: Cascade)
  feedback          TutoringFeedback[]

  @@index([studentUserId, submittedAt])
  @@index([taskId, submittedAt])
}

model TutoringFeedback {
  id               String   @id @default(cuid())
  taskId           String
  submissionId     String?
  reviewerUserId   String
  score            Int?
  comments         String   @db.Text
  strengths        String[] @default([])
  weaknesses       String[] @default([])
  nextAction       String?  @db.Text
  weakTopics       String[] @default([])
  aiSummary        String?  @db.Text
  reviewedAt       DateTime @default(now())
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  task             TutoringTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  submission       TutoringSubmission? @relation(fields: [submissionId], references: [id], onDelete: SetNull)
  reviewer         User         @relation("TutoringFeedbackReviewer", fields: [reviewerUserId], references: [id], onDelete: Cascade)

  @@index([taskId, reviewedAt])
  @@index([reviewerUserId, reviewedAt])
}

model TutoringResource {
  id              String              @id @default(cuid())
  title           String
  subject         String
  topic           String
  kind            TutoringResourceKind
  accessTier      TutoringAccessTier   @default(FREE)
  summary         String?             @db.Text
  fileName        String?
  fileMimeType    String?
  fileBytes       Bytes?
  externalLink    String?
  taskId          String?
  studentUserId   String?
  uploadedByUserId String
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  task            TutoringTask?       @relation(fields: [taskId], references: [id], onDelete: SetNull)
  student         User?               @relation("TutoringResourceStudent", fields: [studentUserId], references: [id], onDelete: Cascade)
  uploadedBy      User                @relation("TutoringResourceUploader", fields: [uploadedByUserId], references: [id], onDelete: Cascade)

  @@index([subject, topic, kind])
  @@index([studentUserId, accessTier])
  @@index([uploadedByUserId, createdAt])
}
