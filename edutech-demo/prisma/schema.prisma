generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          Role      @default(USER)
  plan          String    @default("FREE")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Profile
  gradeLevel         String?
  curriculum         String?
  subjects           String[]
  gpa                Float?
  satScore           Int?
  actScore           Int?
  intendedMajor      String?
  targetUniversities String[]
  careerInterests    String[]
  location           String?
  bio                String?   @db.VarChar(100)
  coursesTaking      String[]  @default([])
  activitiesDone     Json?
  goals              Json?
  customPreferences  String?   @db.Text
  weeklyAvailability Json?

  // Subscription
  stripeCustomerId     String?   @unique
  stripeSubscriptionId String?   @unique
  stripePriceId        String?
  subscriptionStatus   String?
  subscriptionEnds     DateTime?
  trialEnds            DateTime?

  accounts       Account[]
  sessions       Session[]
  studyMaterials StudyMaterial[]
  worksheets     Worksheet[]
  pastPapers     PastPaper[]
  essays         Essay[]
  chatMessages   ChatMessage[]
  studySessions       StudySession[]
  sidebarPreference   SidebarPreference?
  notes               Note[]
  flashcardDecks      FlashcardDeck[]
  flashcards          Flashcard[]
  flashcardReviews    FlashcardReview[]
  userStats           UserStats?
  eventLogs           EventLog[]
  goalsV2             Goal[]
  deadlinesV2         Deadline[]
  calendarEvents      CalendarEvent[]
  feedbackItems       Feedback[]
  practiceSessionsV2  PracticeSession[]
}

model SidebarPreference {
  id            String   @id @default(cuid())
  userId        String   @unique
  collapsed     Boolean  @default(false)
  openGroups    String[] @default([])
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Note {
  id        String   @id @default(cuid())
  userId    String
  title     String
  content   String   @db.Text
  tags      String[] @default([])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, updatedAt])
}

model FlashcardDeck {
  id          String      @id @default(cuid())
  userId      String
  name        String
  description String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  cards       Flashcard[]

  @@index([userId, updatedAt])
}

model Flashcard {
  id        String           @id @default(cuid())
  deckId    String
  userId    String
  front     String           @db.Text
  back      String           @db.Text
  tags      String[]         @default([])
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  deck      FlashcardDeck    @relation(fields: [deckId], references: [id], onDelete: Cascade)
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  reviews   FlashcardReview[]

  @@index([deckId])
  @@index([userId])
}

model FlashcardReview {
  id          String    @id @default(cuid())
  cardId      String
  userId      String
  easiness    Float     @default(2.5)
  interval    Int       @default(1)
  repetitions Int       @default(0)
  dueDate     DateTime  @default(now())
  lastScore   Int?
  reviewedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  card        Flashcard @relation(fields: [cardId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([cardId, userId])
  @@index([userId, dueDate])
}

model UserStats {
  id                    String   @id @default(cuid())
  userId                String   @unique
  studySessionsCount    Int      @default(0)
  notesCount            Int      @default(0)
  flashcardsReviewed    Int      @default(0)
  practiceSessionsCount Int      @default(0)
  correctAnswersCount   Int      @default(0)
  totalAnswersCount     Int      @default(0)
  currentStreakDays     Int      @default(0)
  longestStreakDays     Int      @default(0)
  lastActiveDate        DateTime?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model EventLog {
  id        String   @id @default(cuid())
  userId    String
  eventType String
  meta      Json?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model Goal {
  id          String    @id @default(cuid())
  userId      String
  title       String
  description String?   @db.Text
  status      String    @default("active")
  targetDate  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  deadlines   Deadline[]

  @@index([userId, status])
}

model Deadline {
  id          String    @id @default(cuid())
  userId      String
  goalId      String?
  title       String
  dueAt       DateTime
  priority    String    @default("medium")
  completed   Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  goal        Goal?     @relation(fields: [goalId], references: [id], onDelete: SetNull)

  @@index([userId, dueAt])
}

model CalendarEvent {
  id          String   @id @default(cuid())
  userId      String
  title       String
  startsAt    DateTime
  endsAt      DateTime
  source      String   @default("manual")
  module      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, startsAt])
}

model Question {
  id          String   @id @default(cuid())
  userId      String
  subject     String
  topic       String
  difficulty  String
  stem        String   @db.Text
  options     Json?
  answer      String   @db.Text
  explanation String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId, subject, topic])
}

model PracticeSession {
  id          String           @id @default(cuid())
  userId      String
  subject     String
  startedAt   DateTime         @default(now())
  completedAt DateTime?
  score       Float?
  results     PracticeResult[]
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, startedAt])
}

model PracticeResult {
  id               String          @id @default(cuid())
  sessionId        String
  questionId       String
  selectedAnswer   String?
  isCorrect        Boolean
  createdAt        DateTime        @default(now())
  session          PracticeSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
}

model Feedback {
  id        String   @id @default(cuid())
  userId    String?
  email     String?
  category  String   @default("general")
  message   String   @db.Text
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model ChangelogEntry {
  id        String   @id @default(cuid())
  version   String
  title     String
  content   String   @db.Text
  createdAt DateTime @default(now())

  @@index([createdAt])
}

enum Role {
  USER
  ADMIN
}

model StudyMaterial {
  id          String   @id @default(cuid())
  userId      String
  title       String
  subject     String
  level       String?
  curriculum  String?
  contentType String // text, pdf, url, youtube
  content     String?  @db.Text
  fileUrl     String?
  summary     String?  @db.Text
  notes       String?  @db.Text
  flashcards  Json?
  keyTopics   String[]
  studyPlan   String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Worksheet {
  id           String   @id @default(cuid())
  orgId        String?
  userId       String
  title        String
  subject      String
  curriculum   String?
  difficulty   String
  questionType String
  questions    Json
  answers      Json?
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([orgId, userId, createdAt])
}

model PastPaper {
  id          String    @id @default(cuid())
  userId      String
  subject     String
  curriculum  String
  year        Int?
  duration    Int // minutes
  questions   Json
  answers     Json?
  score       Float?
  timeSpent   Int? // seconds
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Essay {
  id         String   @id @default(cuid())
  userId     String
  type       String // common-app, supplemental, personal-statement
  university String?
  prompt     String?  @db.Text
  draft      String?  @db.Text
  feedback   String?  @db.Text
  improved   String?  @db.Text
  wordCount  Int?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ChatMessage {
  id        String   @id @default(cuid())
  userId    String
  role      String // user, assistant
  content   String   @db.Text
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model StudySession {
  id          String   @id @default(cuid())
  userId      String
  title       String
  subject     String
  curriculum  String?
  content     String   @db.Text
  summary     String?  @db.Text
  flashcards  Json?
  studyPlan   String[] @default([])
  keyConcepts String[] @default([])
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
