# Core
DATABASE_URL="postgresql://postgres:YOUR_POSTGRES_PASSWORD@localhost:5432/edutech"
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="replace-with-a-long-random-secret"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Optional: in production, `/api/health` returns only a minimal payload unless callers send this value as
# `Authorization: Bearer <secret>` or header `x-health-secret: <secret>`. Leave unset in dev for full JSON.
HEALTH_CHECK_SECRET=""

# Auth providers
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# OpenAI
AI_PROVIDER="auto"
GOOGLE_GENAI_USE_VERTEXAI="true"
GOOGLE_CLOUD_PROJECT=""
GOOGLE_CLOUD_LOCATION="us-central1"
GOOGLE_APPLICATION_CREDENTIALS_JSON_B64=""
GEMINI_MODEL="gemini-2.5-flash"
GEMINI_API_KEY=""
OPENAI_API_KEY="sk-..."
OPENAI_MODEL="gpt-4o"
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-3-5-sonnet-20241022"

# Stripe
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_MONTHLY_PRICE_ID=""
STRIPE_YEARLY_PRICE_ID=""
STRIPE_PRO_MONTHLY_PRICE_ID=""
STRIPE_PRO_YEARLY_PRICE_ID=""
STRIPE_PREMIUM_MONTHLY_PRICE_ID=""
STRIPE_PREMIUM_YEARLY_PRICE_ID=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
NEXT_PUBLIC_STRIPE_MONTHLY_PRICE_ID=""
NEXT_PUBLIC_STRIPE_YEARLY_PRICE_ID=""

# Demo mode
DEMO_MODE="false"
NEXT_PUBLIC_DEMO_MODE="false"
DEMO_USER_EMAIL="demo@edutech.local"
DEMO_USER_PASSWORD="demo-password"
DEMO_USER_NAME="Demo Student"
DEMO_USER_ROLE="student"
DEMO_USER_PLAN="premium"
NEXT_PUBLIC_DEMO_USER_EMAIL="demo@edutech.local"
NEXT_PUBLIC_DEMO_USER_PASSWORD="demo-password"
DEMO_STATIC_RESPONSES="false"
AI_DEMO_GUARD="false"
DEMO_ALLOWED_EMAILS=""
DEMO_MAX_AI_CALLS_PER_USER_PER_DAY="20"
DEMO_MAX_AI_CALLS_GLOBAL_PER_DAY="120"

# Feature flags
PUBLIC_SIGNUP_ENABLED="true"
NEXT_PUBLIC_ENABLE_SIGNUP="true"
AOK_TUTOR_INVITE_CODE=""

# WhatsApp OpenClaw
WHATSAPP_ENABLED="false"
WHATSAPP_ACCESS_TOKEN=""
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_VERIFY_TOKEN="replace-with-random-token"
WHATSAPP_APP_SECRET=""
WHATSAPP_GRAPH_API_VERSION="v22.0"
WHATSAPP_ALLOWED_PHONE_NUMBERS=""
WHATSAPP_AI_MODEL=""
WHATSAPP_OPENAI_MODEL="gpt-4o"
WHATSAPP_MAX_TOKENS="300"
OPENCLAW_SYSTEM_PROMPT=""
WHATSAPP_ENFORCE_SIGNATURE="true"
